generator client {
  provider        = "prisma-client-js"
  output          = "../generated/prisma"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

// ── Tenancy & identity ────────────────────────────────────────────────

enum TenantType {
  OWNER
  B2B
}

model Tenant {
  id        String     @id @default(cuid())
  type      TenantType @default(B2B)
  name      String
  createdAt DateTime   @default(now())
  users     User[]
  verticals Vertical[]
  events    Event[]
}

enum UserRole {
  OWNER
  SUBSCRIBER
  TENANT_ADMIN
  TENANT_MEMBER
}

model User {
  id            String         @id @default(cuid())
  tenantId      String
  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  email         String         @unique
  name          String
  passwordHash  String
  role          UserRole       @default(SUBSCRIBER)
  locale        String         @default("en")
  createdAt     DateTime       @default(now())
  subscriptions Subscription[]
  entitlements  Entitlement[]
  events        Event[]
}

model FeatureFlag {
  key         String  @id
  enabled     Boolean @default(false)
  description String  @default("")
}

// ── Verticals & content ───────────────────────────────────────────────

enum VerticalStatus {
  DRAFT
  ACTIVE
  PAUSED
}

enum AutonomyMode {
  REVIEW_FIRST
  FULL_AUTO
}

model Vertical {
  id          String         @id @default(cuid())
  tenantId    String
  tenant      Tenant         @relation(fields: [tenantId], references: [id])
  slug        String
  nameEn      String
  nameAr      String         @default("")
  description String         @default("")
  status      VerticalStatus @default(DRAFT)
  autonomy    AutonomyMode   @default(REVIEW_FIRST)
  isPremium   Boolean        @default(false)
  scoutCron   String         @default("0 6 * * 1")
  taxonomy    Json?
  sourceMap   Json?
  glossary    Json?
  createdAt   DateTime       @default(now())
  sources     Source[]
  documents   Document[]
  courses     Course[]
  briefings   Briefing[]
  proposals   Proposal[]
  skillMemory SkillMemory[]
  entitlements Entitlement[]

  @@unique([tenantId, slug])
}

enum SourceKind {
  WEB
  YOUTUBE
  THREAD
  PDF
  FILE
}

enum SourceStatus {
  QUEUED
  FETCHING
  PROCESSING
  INDEXED
  FAILED
}

model Source {
  id           String       @id @default(cuid())
  verticalId   String
  vertical     Vertical     @relation(fields: [verticalId], references: [id])
  url          String
  kind         SourceKind   @default(WEB)
  status       SourceStatus @default(QUEUED)
  qualityScore Float?
  error        String?
  createdAt    DateTime     @default(now())
  documents    Document[]
}

model Document {
  id         String                      @id @default(cuid())
  verticalId String
  vertical   Vertical                    @relation(fields: [verticalId], references: [id])
  sourceId   String?
  source     Source?                     @relation(fields: [sourceId], references: [id])
  title      String
  lang       String                      @default("en")
  version    Int                         @default(1)
  content    String
  meta       Json?
  embedding  Unsupported("vector(1536)")?
  createdAt  DateTime                    @default(now())
}

enum ContentStatus {
  DRAFT
  IN_REVIEW
  PUBLISHED
  ARCHIVED
}

model Course {
  id         String          @id @default(cuid())
  verticalId String
  vertical   Vertical        @relation(fields: [verticalId], references: [id])
  titleEn    String
  titleAr    String          @default("")
  status     ContentStatus   @default(DRAFT)
  arc        Json?
  createdAt  DateTime        @default(now())
  sessions   CourseSession[]
}

model CourseSession {
  id          String        @id @default(cuid())
  courseId    String
  course      Course        @relation(fields: [courseId], references: [id])
  index       Int
  titleEn     String
  titleAr     String        @default("")
  status      ContentStatus @default(DRAFT)
  planMd      String        @default("")
  guideMd     String        @default("")
  durationMin Int           @default(90)
  createdAt   DateTime      @default(now())
  packs       MaterialPack[]

  @@unique([courseId, index])
}

model Briefing {
  id         String        @id @default(cuid())
  verticalId String
  vertical   Vertical      @relation(fields: [verticalId], references: [id])
  weekOf     DateTime
  lang       String        @default("en")
  title      String
  contentMd  String
  status     ContentStatus @default(DRAFT)
  createdAt  DateTime      @default(now())
  packs      MaterialPack[]
}

enum ProposalKind {
  NEW_TOPIC
  CONTENT_UPDATE
  BRIEFING
}

enum ProposalStatus {
  PENDING
  APPROVED
  REJECTED
}

model Proposal {
  id           String         @id @default(cuid())
  verticalId   String
  vertical     Vertical       @relation(fields: [verticalId], references: [id])
  kind         ProposalKind
  title        String
  summary      String
  diff         Json?
  significance Float          @default(0)
  status       ProposalStatus @default(PENDING)
  createdAt    DateTime       @default(now())
  decidedAt    DateTime?
}

enum MemoryAuthor {
  HUMAN
  AGENT
}

model SkillMemory {
  id         String       @id @default(cuid())
  verticalId String?
  vertical   Vertical?    @relation(fields: [verticalId], references: [id])
  key        String
  version    Int          @default(1)
  content    String
  author     MemoryAuthor @default(AGENT)
  note       String       @default("")
  createdAt  DateTime     @default(now())

  @@index([key, verticalId])
}

enum PackKind {
  PPTX
  DOCX
  PDF
  MD
}

model MaterialPack {
  id          String         @id @default(cuid())
  sessionId   String?
  session     CourseSession? @relation(fields: [sessionId], references: [id])
  briefingId  String?
  briefing    Briefing?      @relation(fields: [briefingId], references: [id])
  kind        PackKind
  lang        String         @default("en")
  storagePath String
  createdAt   DateTime       @default(now())
}

// ── Commercial (built ready, flags off until Stage B/C) ───────────────

enum PlanKind {
  FREE
  VERTICAL
  PREMIUM
  WORKSPACE
}

model Plan {
  id              String         @id @default(cuid())
  code            String         @unique
  nameEn          String
  nameAr          String         @default("")
  kind            PlanKind
  priceMonthlyUsd Float          @default(0)
  stripePriceId   String?
  subscriptions   Subscription[]
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  TRIALING
}

model Subscription {
  id               String             @id @default(cuid())
  userId           String
  user             User               @relation(fields: [userId], references: [id])
  planId           String
  plan             Plan               @relation(fields: [planId], references: [id])
  verticalId       String?
  status           SubscriptionStatus @default(ACTIVE)
  stripeSubId      String?
  currentPeriodEnd DateTime?
  createdAt        DateTime           @default(now())
}

enum EntitlementLevel {
  PREVIEW
  FULL
}

model Entitlement {
  id         String           @id @default(cuid())
  userId     String
  user       User             @relation(fields: [userId], references: [id])
  verticalId String
  vertical   Vertical         @relation(fields: [verticalId], references: [id])
  level      EntitlementLevel @default(PREVIEW)
  source     String           @default("manual")
  createdAt  DateTime         @default(now())

  @@unique([userId, verticalId])
}

model Event {
  id        String   @id @default(cuid())
  tenantId  String?
  tenant    Tenant?  @relation(fields: [tenantId], references: [id])
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  type      String
  payload   Json?
  createdAt DateTime @default(now())

  @@index([type, createdAt])
}
