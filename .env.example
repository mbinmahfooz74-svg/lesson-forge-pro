# Local development (docker compose up -d db)
DATABASE_URL="postgresql://forge:forge_dev_pw@localhost:5433/lessonforge"

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET="dev-secret-change-me"
AUTH_TRUST_HOST=true

# Owner account created by the seed script
OWNER_EMAIL="mbinmahfooz74@gmail.com"
OWNER_PASSWORD="ChangeMe!2026"
OWNER_NAME="M. Bin Mahfooz"

# LLM providers — resolved in this order: Anthropic (production primary),
# Groq (free test phase), OpenAI (production fallback). Any one is enough.
ANTHROPIC_API_KEY=""
GROQ_API_KEY=""
GROQ_MODEL="llama-3.3-70b-versatile"

# Real semantic embeddings (pick one; falls back to offline hashing without either).
# Re-ingest sources after switching providers — vectors are not comparable across them.
OPENAI_API_KEY=""
VOYAGE_API_KEY=""

# Market Scout web search: Tavily (production) or Brave; without a key the scout
# falls back to keyless Google News RSS headlines.
TAVILY_API_KEY=""
BRAVE_API_KEY=""

# Weekly advisory + subscriber digest email (Resend). EMAIL_FROM needs a verified domain.
RESEND_API_KEY=""
EMAIL_FROM=""

# Where generated material packs (pptx/docx/pdf) are written
STORAGE_DIR="./storage/packs"

# Cloud deploy (unused locally) — set these on Vercel/Neon at deploy time
# DATABASE_URL -> managed Postgres with pgvector
# RESEND_API_KEY / STRIPE_SECRET_KEY / STRIPE_WEBHOOK_SECRET -> Stage B
